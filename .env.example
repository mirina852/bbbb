# ============================================
# CREDENCIAIS DA PLATAFORMA (Dono do SaaS)
# ============================================
# Estas credenciais são da SUA conta Mercado Pago (dono da plataforma)
# Usadas para receber pagamentos de ASSINATURAS dos usuários
# O dinheiro das assinaturas cai na SUA conta

# Para o frontend (usado em desenvolvimento)
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Para as Edge Functions do Supabase (usado em produção)
# Estas variáveis devem ser configuradas no painel do Supabase:
# Dashboard > Edge Functions > Secrets
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================
# CREDENCIAIS DOS USUÁRIOS (Lojistas)
# ============================================
# Cada usuário cadastra suas próprias credenciais no painel:
# Configurações > Pagamento
# Usadas para receber pagamentos dos CLIENTES deles
# Armazenadas na tabela: merchant_payment_credentials

# ============================================
# URL DA APLICAÇÃO
# ============================================
# URL base da aplicação (usado para gerar links de lojas)
# Em desenvolvimento: http://localhost:8080
# Em produção: https://seu-app.vercel.app
VITE_APP_URL=http://localhost:8080

# Outras configurações
VITE_API_URL=http://localhost:3000
